CompileFlags:
  Compiler: C:\Users\USER\.platformio\packages\toolchain-xtensa-esp32\bin\xtensa-esp32-elf-g++.exe
  BuiltinHeaders: QueryDriver
  Remove:
    - "-fno-tree-switch-conversion"
    - "-fstrict-volatile-bitfields"
    - "-mlongcalls"
Diagnostics:
  Suppress: [pp_expects_filename, unused-includes]
---
If:
  PathMatch: .*\.ino
CompileFlags:
  Add:
    - "-x"
    - "c++"
    - "-include"
    - "Arduino.h"
